rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && (!request.resource.data.keys().hasAny(['subscription', 'usage']));
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription', 'usage']));
      
      match /passkeys/{document=**} {
        allow read: if isOwner(userId);
        allow write: if false; // Only server can write passkeys
      }
      
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /conversations/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /finx_projects/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /finx_investment_requests/{document=**} {
      allow read, write: if isSignedIn();
    }
    
    match /savedItems/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

